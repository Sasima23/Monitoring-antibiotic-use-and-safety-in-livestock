# ── Server ──────────────────────────────
PORT=5000

# ── MongoDB ─────────────────────────────
# Local: mongodb://localhost:27017/agri_safe_ledger
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/agri_safe_ledger
MONGO_URI=mongodb://localhost:27017/agri_safe_ledger

# ── JWT ─────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Frontend URL (for CORS) ──────────────
CLIENT_URL=http://localhost:8080
